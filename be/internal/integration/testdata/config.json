{
  "version": 3,
  "cli": {
    "default": "claude"
  },
  "spawner": {
    "completion_grace_sec": 60,
    "stats_flush_interval_ms": 2000,
    "stats_flush_max_events": 25,
    "timeout_grace_sec": 5
  },
  "agents": {
    "setup-analyzer": {
      "model": "sonnet",
      "timeout": 15
    },
    "implementor": {
      "model": "opus_4_7",
      "timeout": 30
    },
    "test-writer": {
      "model": "opus_4_7",
      "timeout": 20
    },
    "qa-verifier": {
      "model": "opus_4_7",
      "timeout": 20
    },
    "doc-updater": {
      "model": "sonnet",
      "timeout": 10
    }
  },
  "workflows": {
    "feature": {
      "description": "Full TDD feature development workflow",
      "phases": [
        {"agent": "setup-analyzer", "layer": 0},
        {"agent": "test-writer", "layer": 1},
        {"agent": "implementor", "layer": 2},
        {"agent": "qa-verifier", "layer": 3},
        {"agent": "doc-updater", "layer": 4}
      ]
    },
    "bugfix": {
      "description": "Bug fix workflow - investigation, fix, verify",
      "phases": [
        {"agent": "setup-analyzer", "layer": 0},
        {"agent": "implementor", "layer": 1},
        {"agent": "qa-verifier", "layer": 2}
      ]
    },
    "hotfix": {
      "description": "Emergency hotfix - implementation only",
      "phases": [
        {"agent": "implementor", "layer": 0}
      ]
    },
    "docs": {
      "description": "Documentation-only changes",
      "phases": [
        {"agent": "setup-analyzer", "layer": 0},
        {"agent": "doc-updater", "layer": 1}
      ]
    },
    "refactor": {
      "description": "Code refactoring with verification",
      "phases": [
        {"agent": "setup-analyzer", "layer": 0},
        {"agent": "implementor", "layer": 1},
        {"agent": "qa-verifier", "layer": 2}
      ]
    }
  },
  "storage": {
    "backend": "wfw",
    "data_path": ".claude/nrflo/wfw.data"
  },
  "timeouts": {
    "default_agent_minutes": 25
  },
  "retries": {
    "max_agent_retries": 3
  }
}
